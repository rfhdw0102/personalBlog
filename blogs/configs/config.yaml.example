# 应用配置
app:
  name: "blogs"
  version: "1.0.0"
  mode: "debug"
  port:         # 端口

# 数据库配置
database:
  mysql:
    host: "localhost"
    port: 3306
    username: ""    # 用户
    password: ""    # 密码
    database: ""    # 数据库
    max_idle_conns: 10
    max_open_conns: 100
  redis:
    host: "localhost"
    port: 6379
    password: ""    # 密码
    db:     # 库
    pool_size: 10

# 日志配置
log:
  level: "debug"  # debug, info, warn, error
  filename: "logs/app.log"  # 日志文件
  max_size: 100    # MB
  max_backups: 3   # 保留旧文件的最大个数
  max_age: 28      # 保留旧文件的最大天数
  compress: true   # 是否压缩

# JWT 配置
jwt:
  secret: ""
  expire_hours:   # 过期时间

#邮箱配置
email:
  host: "smtp.qq.com"
  port: 587
  username: ""  # qq邮箱
  password: ""  # 开通smtp后的授权密码，不是qq密码

# CORS 配置
cors:
  enabled: true
  allow_origins:
    - "*"
  allow_methods:
    - "GET"
    - "POST"
    - "PUT"
    - "DELETE"
    - "OPTIONS"
  allow_headers:
    - "Origin"
    - "Content-Type"
    - "Authorization"